{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "routes": [
    {
      "src": "^/player/([^/]+)$",
      "dest": "/player/profile?id=$1"
    },
    {
      "src": "^/pitcher/([^/]+)$",
      "dest": "/pitcher/profile?id=$1"
    },
    {
      "src": "^/sword/([^/]+)$",
      "dest": "/sword/profile?id=$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
